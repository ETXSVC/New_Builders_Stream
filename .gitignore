# OS / Office lock files
~$*
.DS_Store
Thumbs.db

# Claude Code local settings (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Editor
.vscode/

# Git worktrees (isolated implementation workspaces)
.worktrees/

# Local environment secrets (keep .env.example / .env.local.example trackable)
.env
.env*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.coverage

# Node / Next.js
node_modules/
.next/
next-env.d.ts
*.tsbuildinfo

# Playwright e2e artifacts
frontend/test-results/
frontend/playwright-report/

# Redis local snapshot (created by `redis-server` when run from backend/
# during local/manual testing outside docker-compose, which runs Redis in
# its own container instead)
backend/dump.rdb
