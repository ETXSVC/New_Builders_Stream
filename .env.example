# Postgres superuser — used ONLY by Alembic migrations, never by the running app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=builders_stream

# App runtime connection — non-owner role created by migration 0001 (see design decision #1)
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password

DATABASE_URL=postgresql+asyncpg://app_user:app_password@postgres:5432/builders_stream
MIGRATIONS_DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/builders_stream
TEST_DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/builders_stream_test

JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRE_MINUTES=15

REDIS_URL=redis://redis:6379/0

# Task 4.3: Fernet key encrypting integration_connections' OAuth tokens at
# rest. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_TOKEN_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key=

# Local-filesystem root for Document uploads (Task 1.15, design decision #4).
# Matches the `documents_data` Docker volume mounted in docker-compose.yml;
# has a matching default in app/config.py so this line is optional.
STORAGE_ROOT=/data/documents

# Browser-facing origin of the Next.js app — the integrations OAuth callback
# 303-redirects here after a successful connect. docker-compose maps the
# frontend to host port 3001 (app/config.py's default of :3000 suits
# `npm run dev` outside Docker).
FRONTEND_BASE_URL=http://localhost:3001

# Hostname note: DATABASE_URL uses the Docker-network hostname `postgres` because
# it's read by the `backend` container at runtime. MIGRATIONS_DATABASE_URL and
# TEST_DATABASE_URL use `localhost` because Alembic and pytest both run on the
# host, where only `localhost:5432` (published by docker-compose.yml) resolves.
